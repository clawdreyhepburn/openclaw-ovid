{
  "id": "openclaw-ovid",
  "name": "OVID",
  "description": "Agent identity tools — mint, verify, and inspect OVID tokens",
  "version": "0.1.3",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "keyDir": {
        "type": "string",
        "default": "~/.ovid/keys/",
        "description": "Directory for Ed25519 keypair storage"
      },
      "defaultTtl": {
        "type": "number",
        "default": 1800,
        "description": "Default token TTL in seconds"
      },
      "maxTtl": {
        "type": "number",
        "default": 86400
      },
      "maxChainDepth": {
        "type": "number",
        "default": 5
      }
    }
  }
}
