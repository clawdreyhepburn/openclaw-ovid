{
  "id": "openclaw-ovid",
  "name": "OVID",
  "description": "Agent identity tools — mint, verify, and inspect OVID tokens",
  "version": "0.2.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "keyDir": {
        "type": "string",
        "default": "~/.ovid/keys/",
        "description": "Directory for Ed25519 keypair storage"
      },
      "defaultTtl": {
        "type": "number",
        "default": 1800,
        "description": "Default token TTL in seconds"
      },
      "maxTtl": {
        "type": "number",
        "default": 86400
      },
      "maxChainDepth": {
        "type": "number",
        "default": 5
      },
      "autoMint": {
        "type": "boolean",
        "default": true,
        "description": "Auto-mint OVID tokens for spawned sub-agents"
      },
      "defaultMandate": {
        "type": "string",
        "description": "Default Cedar policy for auto-minted tokens (read/search/summarize if omitted)"
      },
      "mandateProfiles": {
        "type": "object",
        "description": "Named mandate profiles. Use [OVID_MANDATE:profileName] in task text to select one.",
        "additionalProperties": {
          "type": "object",
          "properties": {
            "policySet": { "type": "string", "description": "Cedar policy text" },
            "ttl": { "type": "number", "description": "Optional TTL override in seconds" }
          },
          "required": ["policySet"]
        }
      }
    }
  }
}
